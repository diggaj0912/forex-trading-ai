{
  "manifest_version": 3,
  "name": "Stock Signal Scanner (Angel One)",
  "version": "1.0.0",
  "description": "Shows the RSI mean-reversion signal reading for whatever stock you have open on Angel One. Educational/decision-support only, not financial advice.",
  "permissions": ["activeTab", "storage", "scripting"],
  "host_permissions": [
    "https://query1.finance.yahoo.com/*",
    "https://query2.finance.yahoo.com/*",
    "*://*.angelone.in/*",
    "*://*.angelbroking.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["*://*.angelone.in/*", "*://*.angelbroking.com/*"],
      "js": ["content.js"],
      "css": ["overlay.css"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Stock Signal Scanner"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
